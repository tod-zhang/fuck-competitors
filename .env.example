# Copy to .env to override defaults. All vars are prefixed FC_.
FC_DB_URL=sqlite:///./data/app.db
FC_DEFAULT_INTERVAL_HOURS=12
FC_REQUEST_TIMEOUT=20
FC_MAX_SITEMAP_URLS=50000
FC_SNAPSHOT_RETENTION=10
FC_WRITE_BATCH=200
# FC_USER_AGENT=FuckCompetitors/0.1 (+https://github.com/cowseal/fuck-competitors)

# MCP server (app/mcp_server.py): "stdio" (local) or "http" (remote URL)
FC_MCP_TRANSPORT=stdio
FC_MCP_PORT=9528
# FC_MCP_TOKEN=         # set a secret to require Bearer auth — REQUIRED when exposing publicly
